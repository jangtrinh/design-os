{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://ease-design/schemas/flow.schema.json",
  "title": "ease-design flow",
  "description": "A multi-screen design flow: screens (with their data-lifecycle states), transitions, and entry points. Linted deterministically by `ui flow lint`. Guards are declared for linting/handoff, never executed.",
  "type": "object",
  "required": ["screens", "transitions"],
  "additionalProperties": false,
  "properties": {
    "name": { "type": "string" },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string" },
          "mode": { "type": "string", "description": "A mode-constraints UI mode (mobile/desktop/dashboard/admin/ecommerce/app/component/slide)" },
          "artifact": { "type": "string", "description": "The screen's HTML file or Figma node id" },
          "states": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Data-lifecycle states only (default/empty/skeleton/loading/error/success/selected). Pointer states (hover/focus/pressed) are within-screen, not flow nodes."
          },
          "terminal": { "type": "boolean", "default": false }
        }
      }
    },
    "transitions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "from", "to", "trigger"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "from": { "type": "string", "description": "screenId or screenId.stateId" },
          "to": { "type": "string", "description": "screenId or screenId.stateId" },
          "trigger": { "type": "string", "enum": ["ON_CLICK", "ON_HOVER", "ON_PRESS", "AFTER_DELAY", "ON_KEY", "ON_SUBMIT"] },
          "label": { "type": "string" },
          "source": { "type": "string", "description": "The DOM/Figma element that fires the transition" },
          "guard": { "type": "string", "description": "A declared condition — LINTED, never executed" },
          "async": { "type": "boolean", "default": false, "description": "The transition waits on I/O — the from-screen must declare an 'error' state" }
        }
      }
    },
    "entryPoints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "screen"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "screen": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
